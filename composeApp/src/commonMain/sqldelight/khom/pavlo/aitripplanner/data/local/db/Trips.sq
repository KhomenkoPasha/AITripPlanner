deleteLegacyMockTrips:
DELETE FROM TripEntity
WHERE (
  city = 'Rome' AND
  title = 'Rome city highlights' AND
  summary = 'A calm 3-day route shaped around iconic sites, easy walks, and golden-hour breaks.' AND
  hero_note = 'Classic monuments, soft neighborhood pacing, and enough room to slow down.'
) OR (
  city = 'Kyoto' AND
  title = 'Quiet temples and gardens' AND
  summary = 'Temple mornings, tea houses, and a compact walking route.' AND
  hero_note = 'A soft, reflective city break with low-friction transitions.'
) OR (
  city = 'Lisbon' AND
  title = 'Coastal neighborhoods' AND
  summary = 'Viewpoints, trams, tiled streets, and sunset pacing.' AND
  hero_note = 'A bright route mixing landmarks and softer local rhythm.'
