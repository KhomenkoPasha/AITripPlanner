CREATE TABLE TripEntity (
  id TEXT NOT NULL PRIMARY KEY,
  city TEXT NOT NULL,
  title TEXT NOT NULL,
  summary TEXT NOT NULL,
  hero_note TEXT NOT NULL,
  duration_minutes INTEGER NOT NULL,
  distance_km REAL NOT NULL,
  is_favorite INTEGER NOT NULL,
  is_offline_only INTEGER NOT NULL,
  is_pending_sync INTEGER NOT NULL,
  remote_version INTEGER NOT NULL,
  updated_at_epoch_ms INTEGER NOT NULL
);

CREATE TABLE DayEntity (
  id TEXT NOT NULL PRIMARY KEY,
  trip_id TEXT NOT NULL,
  day_index INTEGER NOT NULL,
  title TEXT NOT NULL,
  summary TEXT NOT NULL,
  duration_minutes INTEGER NOT NULL,
  distance_km REAL NOT NULL,
  is_expanded INTEGER NOT NULL
);

CREATE TABLE PlaceEntity (
  id TEXT NOT NULL PRIMARY KEY,
  day_id TEXT NOT NULL,
  sort_index INTEGER NOT NULL,
  name TEXT NOT NULL,
  latitude REAL,
  longitude REAL,
  address TEXT NOT NULL,
  visit_minutes INTEGER NOT NULL,
  note TEXT NOT NULL,
  category TEXT,
  short_description TEXT NOT NULL,
  full_description TEXT NOT NULL,
  why_included TEXT NOT NULL,
  tips_text TEXT NOT NULL,
  opening_hours_text TEXT NOT NULL,
  best_time_to_visit TEXT NOT NULL,
  is_open_now INTEGER,
  website_url TEXT,
  photo_url TEXT,
  photo_urls_text TEXT NOT NULL,
  photo_attribution TEXT,
  price_level TEXT,
  visit_notes TEXT NOT NULL,
  neighborhood TEXT NOT NULL,
  stop_index INTEGER,
  previous_place_name TEXT,
  next_place_name TEXT,
  is_completed INTEGER NOT NULL
);

CREATE TABLE SyncQueueEntity (
  id TEXT NOT NULL PRIMARY KEY,
  entity_id TEXT NOT NULL,
  entity_type TEXT NOT NULL,
  operation TEXT NOT NULL,
  payload_json TEXT NOT NULL,
  state TEXT NOT NULL,
  attempt_count INTEGER NOT NULL,
  base_version INTEGER,
  conflict_token TEXT,
  last_error TEXT,
  created_at_epoch_ms INTEGER NOT NULL,
  updated_at_epoch_ms INTEGER NOT NULL
);

CREATE TABLE AppSettingsEntity (
  id INTEGER NOT NULL PRIMARY KEY,
  app_language TEXT NOT NULL
);

seedSettings:
INSERT OR IGNORE INTO AppSettingsEntity(id, app_language) VALUES (1, 'EN');

selectAppLanguage:
SELECT app_language FROM AppSettingsEntity WHERE id = 1;

updateAppLanguage:
INSERT OR REPLACE INTO AppSettingsEntity(id, app_language) VALUES (1, ?);

selectTrips:
SELECT * FROM TripEntity ORDER BY updated_at_epoch_ms DESC;

selectAllDays:
SELECT * FROM DayEntity ORDER BY day_index ASC;

selectAllPlaces:
SELECT * FROM PlaceEntity ORDER BY sort_index ASC;

selectDayIdsByTripId:
SELECT id FROM DayEntity WHERE trip_id = ?;

insertTrip:
INSERT OR REPLACE INTO TripEntity(
  id, city, title, summary, hero_note, duration_minutes, distance_km,
  is_favorite, is_offline_only, is_pending_sync, remote_version, updated_at_epoch_ms
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

insertDay:
INSERT OR REPLACE INTO DayEntity(
  id, trip_id, day_index, title, summary, duration_minutes, distance_km, is_expanded
) VALUES (?, ?, ?, ?, ?, ?, ?, ?);

insertPlace:
INSERT OR REPLACE INTO PlaceEntity(
  id, day_id, sort_index, name, latitude, longitude, address, visit_minutes, note, category,
  short_description, full_description, why_included, tips_text, opening_hours_text, best_time_to_visit,
  is_open_now, website_url, photo_url, photo_urls_text, photo_attribution, price_level, visit_notes,
  neighborhood, stop_index, previous_place_name, next_place_name, is_completed
) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

deleteTripById:
DELETE FROM TripEntity WHERE id = ?;

deleteDaysByTripId:
DELETE FROM DayEntity WHERE trip_id = ?;

deletePlacesByDayId:
DELETE FROM PlaceEntity WHERE day_id = ?;

deleteSyncItemsByEntityId:
DELETE FROM SyncQueueEntity WHERE entity_id = ?;

deleteLegacyMockPlaces:
DELETE FROM PlaceEntity
WHERE day_id IN (
  SELECT id FROM DayEntity
  WHERE trip_id IN (
    SELECT id FROM TripEntity
    WHERE (
      city = 'Rome' AND
      title = 'Rome city highlights' AND
      summary = 'A calm 3-day route shaped around iconic sites, easy walks, and golden-hour breaks.' AND
      hero_note = 'Classic monuments, soft neighborhood pacing, and enough room to slow down.'
    ) OR (
      city = 'Kyoto' AND
      title = 'Quiet temples and gardens' AND
      summary = 'Temple mornings, tea houses, and a compact walking route.' AND
      hero_note = 'A soft, reflective city break with low-friction transitions.'
    ) OR (
      city = 'Lisbon' AND
      title = 'Coastal neighborhoods' AND
      summary = 'Viewpoints, trams, tiled streets, and sunset pacing.' AND
      hero_note = 'A bright route mixing landmarks and softer local rhythm.'
    )
  )
);

